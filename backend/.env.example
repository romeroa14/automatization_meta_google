APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=admetricas
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Sanctum (SPA / cookies) — debe incluir host:puerto del frontend que llama al API
# Ejemplo local: localhost,127.0.0.1,localhost:5173
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000,::1

# -----------------------------------------------------------------------------
# Facebook — OAuth redirect + WhatsApp Embedded Signup + verificación webhook
# App ID / Secret pueden gestionarse también vía Filament (FacebookAccount).
# -----------------------------------------------------------------------------
FACEBOOK_REDIRECT_URI=http://localhost:9000/auth/facebook/callback
FACEBOOK_WA_SIGNUP_CONFIG_ID=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=admetricas_webhook_token

# -----------------------------------------------------------------------------
# WhatsApp Cloud API — valores por defecto / entorno de prueba
# En multi-tenant, token y phone_number_id suelen venir de BD por cliente.
# -----------------------------------------------------------------------------
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# -----------------------------------------------------------------------------
# Instagram / Meta
# -----------------------------------------------------------------------------
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_VERIFY_TOKEN=adsbot
INSTAGRAM_APP_SECRET=
INSTAGRAM_APP_ID=

# -----------------------------------------------------------------------------
# n8n — webhooks de integración (comentarios, WhatsApp, genérico)
# -----------------------------------------------------------------------------
N8N_WEBHOOK_URL=
N8N_COMMENTS_WEBHOOK_URL=
N8N_WHATSAPP_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# IA y Google (Sheets / webapp)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=
GOOGLE_WEBAPP_URL=

# -----------------------------------------------------------------------------
# Airtable
# -----------------------------------------------------------------------------
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# -----------------------------------------------------------------------------
# Telegram (campañas Meta + defaults)
# TELEGRAM_WEBHOOK_URL opcional; por defecto APP_URL + /api/telegram/webhook
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_URL=
DEFAULT_FACEBOOK_ACCOUNT_ID=
DEFAULT_AD_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Email alternativos (config/services.php)
# -----------------------------------------------------------------------------
POSTMARK_TOKEN=
RESEND_KEY=

# -----------------------------------------------------------------------------
# Slack (notificaciones)
# -----------------------------------------------------------------------------
SLACK_BOT_USER_OAUTH_TOKEN=
SLACK_BOT_USER_DEFAULT_CHANNEL=
